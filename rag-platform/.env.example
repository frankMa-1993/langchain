DATABASE_URL=sqlite:///./rag_platform.db
REDIS_URL=
QDRANT_URL=./.qdrant
QDRANT_COLLECTION=kb_chunks

# Legacy OpenAI-compatible settings. Safe to leave blank when using CHAT_* below.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Recommended stable chat setup: DeepSeek chat only
CHAT_API_KEY=sk-5b12528b57a84ebf8397a34f3c81207b
CHAT_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-chat

# Optional semantic search provider (disabled by default)
SEMANTIC_SEARCH_ENABLED=false
SEMANTIC_API_KEY=
SEMANTIC_BASE_URL=
SEMANTIC_MODEL=
SEMANTIC_DIMENSIONS=0

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_MB=50
UPLOAD_DIR=./uploads

# Optional: require X-API-Key header matching this value
# API_KEY=

# Rate limit: requests per minute per IP (0 = disabled)
RATE_LIMIT_PER_MINUTE=60
